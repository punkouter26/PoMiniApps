@page "/diag"
@using System.Net.Http.Json
@using System.Text.Json
@inject HttpClient Http
@rendermode InteractiveWebAssembly

<PageTitle>PoMiniApps — Diagnostics</PageTitle>

<div class="diagnostics-container">
    <div class="diagnostics-header">
        <RadzenLink Path="/" Text="← Back to Playground" Style="color: rgba(255,255,255,0.7); font-size: 0.9rem;" />
        <h2 class="diagnostics-title">🔧 System Diagnostics</h2>
        <p style="color: var(--text-tertiary); margin-top: 0.5rem;">Check the health of all connected services and
            dependencies</p>
        </div>

        <RadzenButton Text="🔄 Run All Checks" Icon="play_arrow" Click="@RunDiagnosticsAsync"
                      ButtonStyle="ButtonStyle.Primary" Size="ButtonSize.Large"                  IsBusy="@_loading" class="rz-mb-4"
                      Style="width: 100%;" />

        @if (_loading)
        {
            <div style="display: flex; align-items: center; justify-content: center; gap: 1rem; padding: 2rem;">
                <RadzenProgressBarCircular ShowValue="false" Mode="ProgressBarMode.Indeterminate" />
                <span>Running system diagnostics...</span>
            </div>
        }
        else if (_results is not null)
        {
            <div class="diagnostics-summary">
                <div class="summary-card">
                    <div class="summary-label">Total Checks</div>
                    <div class="summary-value">@_results.Count</div>
                </div>
                <div class="summary-card" style="border-left-color: var(--success-color);">
                    <div class="summary-label">Passed</div>
                    <div class="summary-value" style="color: var(--success-color);">@_results.Count(r => r.Success)</div>
                </div>
                <div class="summary-card"
                     style="border-left-color: @(_results.Any(r => !r.Success) ? "var(--danger-color)" : "var(--success-color)");">
                    <div class="summary-label">Failed</div>
                    <div class="summary-value"
                         style="color: @(_results.Any(r => !r.Success) ? "var(--danger-color)" : "var(--success-color)");">
                        @_results.Count(r => !r.Success)</div>
                    </div>
                </div>

                @if (_results.GroupBy(r => r.Category).Count() > 0)
                {
                    @foreach (var categoryGroup in _results.GroupBy(r => r.Category).OrderBy(g => g.Key))
                    {
                        <div class="diagnostics-section">
                            <h3 class="diagnostics-section-title">@categoryGroup.Key</h3>

                            @foreach (var item in categoryGroup.OrderByDescending(r => r.Success))
                            {
                                <div class="diag-item @(item.Success ? "success" : item.IsWarning ? "warning" : "error")">
                                    <div class="diag-item-content">
                                        <div class="diag-item-name">@item.CheckName</div>
                                        <div class="diag-item-message">@item.Message</div>
                                    </div>
                                    <div class="diag-item-status @(item.Success ? "success" : item.IsWarning ? "warning" : "error")">
                                        @if (item.Success)
                                        {
                                            <span>✅ Healthy</span>
                                        }
                                        else if (item.IsWarning)
                                        {
                                            <span>⚠️ Warning</span>
                                        }
                                        else
                                        {
                                            <span>❌ Failed</span>
                                        }
                                    </div>
                                </div>
                            }
                        </div>
                    }
                }

                <div class="diagnostics-section" style="margin-top: 2rem;">
                    <h3 class="diagnostics-section-title">📋 Configuration Snapshot</h3>
                    <div class="config-snapshot">
                        <pre>@_configJson</pre>
                    </div>
                    <RadzenButton Text="📋 Copy Configuration" Icon="content_copy" ButtonStyle="ButtonStyle.Secondary"
                                  Style="margin-top: 1rem; width: 100%;" />
                </div>
            }
        </div>

@code {
    private List<DiagResult>? _results;
    private string _configJson = "{}";
    private bool _loading;

    protected override async Task OnInitializedAsync() => await RunDiagnosticsAsync();

    private async Task RunDiagnosticsAsync()
    {
        _loading = true;
        try
        {
            _results = await Http.GetFromJsonAsync<List<DiagResult>>("/api/diagnostics");
            var config = await Http.GetFromJsonAsync<Dictionary<string, string>>("/api/diagnostics/config");
            _configJson = JsonSerializer.Serialize(config ?? new Dictionary<string, string>(), new JsonSerializerOptions
            {
                WriteIndented = true
            });
        }
        catch (Exception ex)
        {
            _results = [new DiagResult { CheckName = "HTTP Request", Category = "System", Success = false, IsWarning = false,
Message = $"Failed: {ex.Message}" }];
            _configJson = JsonSerializer.Serialize(
                new Dictionary<string, string> { ["error"] = ex.Message },
                new JsonSerializerOptions { WriteIndented = true });
        }
        finally { _loading = false; }
    }

    private class DiagResult
    {
        public string CheckName { get; set; } = "";
        public string Category { get; set; } = "Other";
        public bool Success { get; set; }
        public bool IsWarning { get; set; }
        public string Message { get; set; } = "";
    }
}