@inherits LayoutComponentBase
@inject NavigationManager Navigation

<RadzenLayout>
    <RadzenHeader>
        <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="1rem" class="rz-p-2">
            <RadzenLink Path="/" Text="🚀 PoMiniApps"
                        Style="font-size: 1.5rem; font-weight: bold; color: white; text-decoration: none;" />

            @if (!IsHomePage && CurrentAppName != null)
            {
                <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem"
                             Style="margin-left: auto; font-size: 0.9rem;">
                    <RadzenLink Path="/" Icon="home" IconColor="rgba(255,255,255,0.6)"                                Style="color: rgba(255,255,255,0.6);"
                                title="Home" />
                    <span style="color: rgba(255,255,255,0.3);">›</span>
                    <span style="color: rgba(255,255,255,0.7);">@CurrentAppName</span>
                </RadzenStack>
            }
        </RadzenStack>
    </RadzenHeader>
    <RadzenBody>
        <div class="rz-p-4">
            @Body
        </div>
    </RadzenBody>
    <RadzenFooter>
        <div class="rz-text-align-center rz-p-2" style="font-size: 0.8rem; color: #aaa;">
            <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.Center" Gap="2rem"
                         AlignItems="AlignItems.Center">
                <span>PoMiniApps &copy; @DateTime.UtcNow.Year</span>
                <RadzenLink Path="/diag" Icon="settings" Text="Diagnostics"
                            Style="color: rgba(255,255,255,0.5); font-size: 0.8rem;" title="System Diagnostics" />
            </RadzenStack>
        </div>
    </RadzenFooter>
</RadzenLayout>

<RadzenDialog />
<RadzenNotification />
<RadzenTooltip />

@code {
    private bool IsHomePage => Navigation.Uri == Navigation.BaseUri || Navigation.ToBaseRelativePath(Navigation.Uri) == "";

    private string? CurrentAppName
    {
        get
        {
            var path = Navigation.ToBaseRelativePath(Navigation.Uri).ToLowerInvariant();
            if (path.Contains("rap-battle") || path.Contains("rap-debate")) return "Rap Battle Arena";
            if (path.Contains("victorian") || path.Contains("translat")) return "Victorian Translator";
            return null;
        }
    }

    private string CurrentAppRoute
    {
        get
        {
            var path = Navigation.ToBaseRelativePath(Navigation.Uri).ToLowerInvariant();
            if (path.Contains("rap-battle") || path.Contains("rap-debate")) return "/apps/lingual/rap-battle";
            if (path.Contains("victorian") || path.Contains("translat")) return "/apps/lingual/victorian-translator";
            return "/";
        }
    }

    private string? CurrentPageName
    {
        get
        {
            var path = Navigation.ToBaseRelativePath(Navigation.Uri).ToLowerInvariant();
            if (path.Contains("diagnostics")) return "Diagnostics";
            return null;
        }
    }

    protected override void OnInitialized()
    {
        Navigation.LocationChanged += (s, e) => StateHasChanged();
    }
}