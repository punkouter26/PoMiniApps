@page "/apps/lingual/victorian-translator"
@page "/translate"
@page "/translation"
@layout MainLayout
@using System.Net.Http.Json
@inject HttpClient Http
@inject IJSRuntime JS
@inject NavigationManager Navigation
@rendermode InteractiveWebAssembly

<PageTitle>Victorian Translator - PoMiniApps</PageTitle>

<div class="victorian-page">
    <div class="victorian-header">
        <h2 class="victorian-title">🎩 Victorian English Translator</h2>
    </div>

    <RadzenCard class="setup-card" Style="max-width: 900px;">
        <RadzenStack Gap="1.5rem">
            <RadzenText TextStyle="TextStyle.H5">Transform Modern English into Victorian Prose</RadzenText>

            <RadzenFormField Text="Enter text to translate" Style="width: 100%;">
                <ChildContent>
                    <RadzenTextArea Value="@_inputText" ValueChanged="@OnTextChanged" Rows="6"
                                    Placeholder="Enter modern English text (e.g., 'hey, what's up?') or use Quick Fill below..."
                                    Style="width: 100%;" Disabled="@_isTranslating" />
                </ChildContent>
                <Helper>
                    <div
                        style="display: flex; justify-content: space-between; align-items: center; margin-top: 0.5rem;">
                        <RadzenStack Orientation="Orientation.Horizontal" Gap="0.5rem" AlignItems="AlignItems.Center">
                            <span style="color: var(--rz-text-secondary-color); font-size: 0.85rem;">Quick Fill:</span>
                            <RadzenButton Text="🎲 Random" Size="ButtonSize.ExtraSmall" ButtonStyle="ButtonStyle.Light"
                                          Variant="Variant.Outlined" Click="@LoadRandomLyrics" Disabled="@_isTranslating" />
                            @if (_availableSongs is not null && _availableSongs.Count > 0)
                            {
                                <RadzenDropDown @bind-Value="@_selectedSong" Data="@_availableSongs"
                                                Placeholder="or choose song..." Size="ButtonSize.ExtraSmall"
                                                Style="width: 180px; font-size: 0.85rem;" Change="@OnSongSelected"
                                                Disabled="@_isTranslating" />
                            }
                            else
                            {
                                <small style="color: var(--rz-text-tertiary-color); font-size: 0.85rem;">No songs available
                                    yet</small>
                                }
                            </RadzenStack>
                            <span style="color: var(--rz-text-secondary-color); font-size: 0.85rem;">@_inputText.Length
                                characters</span>
                            </div>
                        </Helper>
                    </RadzenFormField>

                    <RadzenButton Text="Translate to Victorian" Icon="translate" Click="@TranslateAsync"
                                  ButtonStyle="ButtonStyle.Primary" Size="ButtonSize.Large" IsBusy="@_isTranslating"
                                  Disabled="@(string.IsNullOrWhiteSpace(_inputText) || _isTranslating)" Style="width: 100%;" />

                    @if (!string.IsNullOrWhiteSpace(_errorMessage))
                    {
                        <RadzenAlert AlertStyle="AlertStyle.Danger" Variant="Variant.Flat" Shade="Shade.Lighter"
                                     Color="AlertColor.Danger">
                            <strong>⚠️ Translation Error:</strong> @_errorMessage
                            <div style="margin-top: 0.5rem;">
                                <RadzenButton Text="Try Again" Click="@TranslateAsync" ButtonStyle="ButtonStyle.Secondary"
                                              Size="ButtonSize.Small" />
                            </div>
                        </RadzenAlert>
                    }

                    @if (_isTranslating)
                    {
                        <div class="progress-indicator">
                            <RadzenProgressBarCircular ShowValue="false" Mode="ProgressBarMode.Indeterminate"
                                                       Size="ProgressBarCircularSize.Small" />
                            <span>Transforming to Victorian prose...</span>
                        </div>
                    }
                </RadzenStack>
            </RadzenCard>

            @if (!string.IsNullOrWhiteSpace(_translatedText))
            {
                <RadzenCard class="setup-card" Style="max-width: 900px; margin-top: 2rem;">
                    <RadzenStack Gap="1.5rem">
                        <div>
                            <RadzenText TextStyle="TextStyle.H5" style="margin-bottom: 1rem;">📜 Victorian Translation</RadzenText>
                            <div
                                style="background: rgba(0, 0, 0, 0.2); padding: 1.5rem; border-radius: 8px; border-left: 4px solid var(--secondary-color);">
                                <RadzenText
                                    Style="white-space: pre-wrap; font-style: italic; line-height: 1.8; color: var(--text-secondary);">
                                    @_translatedText</RadzenText>
                                </div>
                            </div>

                            <RadzenStack Orientation="Orientation.Horizontal" Gap="1rem" Wrap="FlexWrap.Wrap">
                                <RadzenButton Text="Hear It in British Accent" Icon="volume_up" Click="@SynthesizeSpeechAsync"
                                              ButtonStyle="ButtonStyle.Info" Size="ButtonSize.Large" IsBusy="@_isSynthesizing"
                                              Disabled="@_isSynthesizing" Style="flex: 1; min-width: 200px;" />
                                <RadzenButton Text="Copy to Clipboard" Icon="content_copy" ButtonStyle="ButtonStyle.Secondary"
                                              Size="ButtonSize.Large" Style="flex: 1; min-width: 200px;" Click="@CopyToClipboardAsync" />
                            </RadzenStack>

                            @if (_isSynthesizing)
                            {
                                <div class="progress-indicator">
                                    <RadzenProgressBarCircular ShowValue="false" Mode="ProgressBarMode.Indeterminate"
                                                               Size="ProgressBarCircularSize.Small" />
                                    <span>Generating speech with British accent...</span>
                                </div>
                            }

                            <RadzenButton Text="Translate Another" Icon="repeat" ButtonStyle="ButtonStyle.Light"
                                          Variant="Variant.Outlined" Click="@ResetTranslation" Style="width: 100%;" />
                        </RadzenStack>
                    </RadzenCard>
                }
            </div>

@code {
    private string _inputText = "";
    private string _translatedText = "";
    private string _errorMessage = "";
    private string? _selectedSong;
    private List<string>? _availableSongs;
    private bool _isTranslating;
    private bool _isSynthesizing;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var baseUrl = Navigation.BaseUri.TrimEnd('/');
            _availableSongs = await Http.GetFromJsonAsync<List<string>>($"{baseUrl}/api/lyrics/songs");
        }
        catch { /* Songs unavailable - gracefully degrade */ }
    }

    /// <summary>
    /// Handle text changes and explicitly trigger component re-render
    /// to update character count display.
    /// </summary>
    private Task OnTextChanged(string? value)
    {
        _inputText = value ?? "";
        // Explicitly trigger state change for proper binding updates
        return InvokeAsync(StateHasChanged);
    }

    private async Task OnSongSelected(object value)
    {
        if (value is string song && !string.IsNullOrWhiteSpace(song))
        {
            try
            {
                var baseUrl = Navigation.BaseUri.TrimEnd('/');
                var result = await Http.GetFromJsonAsync<LyricsResult>($"{baseUrl}/api/lyrics/{Uri.EscapeDataString(song)}");
                if (result?.Lyrics is not null)
                {
                    _inputText = result.Lyrics;
                    await InvokeAsync(StateHasChanged);
                }
            }
            catch { _errorMessage = "Failed to load song lyrics. Please try again."; }
        }
    }

    private async Task LoadRandomLyrics()
    {
        try
        {
            var baseUrl = Navigation.BaseUri.TrimEnd('/');
            var result = await Http.GetFromJsonAsync<LyricsResult>($"{baseUrl}/api/lyrics/random");
            if (result is not null)
            {
                _inputText = result.Lyrics ?? "";
                _selectedSong = result.Title;
                await InvokeAsync(StateHasChanged);
            }
        }
        catch { _errorMessage = "Failed to load random lyrics. Check your connection and try again."; }
    }

    private async Task TranslateAsync()
    {
        _isTranslating = true;
        _errorMessage = "";
        _translatedText = "";
        try
        {
            var baseUrl = Navigation.BaseUri.TrimEnd('/');
            var response = await Http.PostAsJsonAsync($"{baseUrl}/api/translation", new { Text = _inputText });
            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<TranslationResult>();
                _translatedText = result?.TranslatedText ?? "";
            }
            else if (response.StatusCode == System.Net.HttpStatusCode.BadRequest)
            {
                var problem = await response.Content.ReadFromJsonAsync<System.Text.Json.JsonElement>();
                _errorMessage = problem.TryGetProperty("detail", out var detail)
                    ? detail.GetString() ?? "The text could not be translated. Please try different content."
                    : "The text could not be translated. Please try different content.";
            }
            else
            {
                _errorMessage = "Translation failed. Please try again with shorter text.";
            }
        }
        catch (Exception ex) { _errorMessage = $"Connection error: {ex.Message}. Please check your internet."; }
        finally { _isTranslating = false; }
    }

    private async Task SynthesizeSpeechAsync()
    {
        _isSynthesizing = true;
        try
        {
            await JS.InvokeAsync<bool>("audioInterop.unlockAudio");
            var baseUrl = Navigation.BaseUri.TrimEnd('/');
            var response = await Http.PostAsJsonAsync($"{baseUrl}/api/speech/synthesize", new { Text = _translatedText });
            if (response.IsSuccessStatusCode)
            {
                var audioBytes = await response.Content.ReadAsByteArrayAsync();
                var base64 = Convert.ToBase64String(audioBytes);
                var played = await JS.InvokeAsync<bool>("audioInterop.playAudioFromBase64", base64, "wav");
                if (!played)
                {
                    _errorMessage = "Audio playback was blocked by the browser. Click the button again to allow sound.";
                }
            }
            else _errorMessage = "Speech synthesis failed. Please try again.";
        }
        catch (Exception ex) { _errorMessage = $"Speech error: {ex.Message}"; }
        finally { _isSynthesizing = false; }
    }

    private async Task CopyToClipboardAsync()
    {
        try
        {
            await JS.InvokeVoidAsync("navigator.clipboard.writeText", _translatedText);
            _errorMessage = "";
        }
        catch
        {
            _errorMessage = "Could not copy to clipboard. Please select and copy the text manually.";
        }
    }

    private void ResetTranslation()
    {
        _inputText = "";
        _translatedText = "";
        _errorMessage = "";
    }

    private record TranslationResult(string TranslatedText);
    private record LyricsResult(string? Title, string? Lyrics);
}