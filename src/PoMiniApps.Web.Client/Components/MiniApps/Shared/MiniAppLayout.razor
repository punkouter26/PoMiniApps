@inherits LayoutComponentBase

<div class="miniapp-container">
    <div class="miniapp-header">
        <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="1rem" class="miniapp-nav">
            <RadzenLink Path="/" Icon="home" Text="Home" Style="color: rgba(255,255,255,0.9); font-size: 0.95rem;" />
            <span style="color: rgba(255,255,255,0.4);">›</span>
            <span style="color: rgba(255,255,255,0.7); font-size: 0.95rem;">@AppTitle</span>
        </RadzenStack>
    </div>

    <div class="miniapp-content">
        @Body
    </div>
</div>

@code {
    [Parameter]
    public string AppTitle { get; set; } = "Mini App";
}