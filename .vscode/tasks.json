{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "cleanup-dotnet-processes",
      "type": "shell",
      "windows": {
        "command": "powershell",
        "args": [
          "-NoProfile",
          "-Command",
          "$p = Get-Process | Where-Object { ($_.ProcessName -like \"dotnet*\" -or $_.ProcessName -like \"PoMiniApps*\") -and $_.Id -ne $PID }; if ($p) { foreach ($proc in $p) { Write-Host \"Killing $($proc.ProcessName) (PID: $($proc.Id))\"; Stop-Process -Id $proc.Id -Force -ErrorAction SilentlyContinue } } else { Write-Host \"No dotnet processes found\" }; Start-Sleep -Seconds 1"
        ]
      },
      "linux": {
        "command": "bash",
        "args": [
          "-c",
          "pkill -f 'dotnet' || true; sleep 1"
        ]
      },
      "osx": {
        "command": "bash",
        "args": [
          "-c",
          "pkill -f 'dotnet' || true; sleep 1"
        ]
      },
      "presentation": {
        "echo": true,
        "reveal": "silent",
        "focus": false,
        "panel": "shared",
        "showReuseMessage": false,
        "clear": false
      },
      "problemMatcher": []
    },
    {
      "label": "build-server",
      "command": "dotnet",
      "type": "process",
      "args": [
        "build",
        "${workspaceFolder}/src/PoMiniApps.Web/PoMiniApps.Web.csproj",
        "/property:GenerateFullPaths=true",
        "/consoleloggerparameters:NoSummary;ForceNoAlign"
      ],
      "problemMatcher": "$msCompile",
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "label": "watch-server",
      "command": "dotnet",
      "type": "process",
      "args": [
        "watch",
        "run",
        "--non-interactive",
        "--project",
        "${workspaceFolder}/src/PoMiniApps.Web/PoMiniApps.Web.csproj"
      ],
      "problemMatcher": "$msCompile",
      "isBackground": true
    },
    {
      "label": "watch-server-http",
      "type": "shell",
      "windows": {
        "command": "powershell",
        "args": [
          "-NoProfile",
          "-Command",
          "$env:ASPNETCORE_URLS='http://localhost:5000'; cd '${workspaceFolder}'; dotnet watch run --project src/PoMiniApps.Web/PoMiniApps.Web.csproj"
        ]
      },
      "linux": {
        "command": "bash",
        "args": [
          "-c",
          "export ASPNETCORE_URLS='http://localhost:5000' && cd '${workspaceFolder}' && dotnet watch run --project src/PoMiniApps.Web/PoMiniApps.Web.csproj"
        ]
      },
      "osx": {
        "command": "bash",
        "args": [
          "-c",
          "export ASPNETCORE_URLS='http://localhost:5000' && cd '${workspaceFolder}' && dotnet watch run --project src/PoMiniApps.Web/PoMiniApps.Web.csproj"
        ]
      },
      "problemMatcher": "$msCompile",
      "isBackground": true,
      "presentation": {
        "reveal": "always",
        "panel": "new"
      }
    },
    {
      "label": "clean",
      "command": "dotnet",
      "type": "process",
      "args": [
        "clean",
        "${workspaceFolder}/PoMiniApps.slnx"
      ],
      "problemMatcher": "$msCompile"
    },
    {
      "label": "build-solution",
      "command": "dotnet",
      "type": "process",
      "args": [
        "build",
        "${workspaceFolder}/PoMiniApps.slnx",
        "/property:GenerateFullPaths=true",
        "/consoleloggerparameters:NoSummary;ForceNoAlign"
      ],
      "problemMatcher": "$msCompile",
      "group": "build"
    },
    {
      "label": "start-azurite",
      "type": "shell",
      "command": "docker",
      "args": [
        "compose",
        "up",
        "-d"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "stop-azurite",
      "type": "shell",
      "command": "docker",
      "args": [
        "compose",
        "down"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "f5-launch-edge",
      "type": "shell",
      "windows": {
        "command": "powershell",
        "args": [
          "-NoProfile",
          "-Command",
          "$p = Get-Process | Where-Object { ($_.ProcessName -like 'dotnet*' -or $_.ProcessName -like 'PoMiniApps*') -and $_.Id -ne $PID }; if ($p) { foreach ($proc in $p) { Stop-Process -Id $proc.Id -Force -ErrorAction SilentlyContinue } }; Start-Sleep -Seconds 1; $env:ASPNETCORE_URLS='http://localhost:5000'; cd '${workspaceFolder}'; dotnet watch run --project src/PoMiniApps.Web/PoMiniApps.Web.csproj"
        ]
      },
      "linux": {
        "command": "bash",
        "args": [
          "-c",
          "pkill -f 'dotnet' || true; sleep 1; export ASPNETCORE_URLS='http://localhost:5000' && cd '${workspaceFolder}' && dotnet watch run --project src/PoMiniApps.Web/PoMiniApps.Web.csproj"
        ]
      },
      "osx": {
        "command": "bash",
        "args": [
          "-c",
          "pkill -f 'dotnet' || true; sleep 1; export ASPNETCORE_URLS='http://localhost:5000' && cd '${workspaceFolder}' && dotnet watch run --project src/PoMiniApps.Web/PoMiniApps.Web.csproj"
        ]
      },
      "problemMatcher": "$msCompile",
      "isBackground": true,
      "presentation": {
        "reveal": "always",
        "panel": "new",
        "focus": true
      }
    }
  ]
}