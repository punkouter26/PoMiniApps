{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug Blazor Web App",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build-server",
      "program": "${workspaceFolder}/src/PoMiniApps.Web/bin/Debug/net10.0/PoMiniApps.Web.dll",
      "args": [],
      "cwd": "${workspaceFolder}/src/PoMiniApps.Web",
      "stopAtEntry": false,
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development",
        "ASPNETCORE_URLS": "https://localhost:5001;http://localhost:5000"
      },
      "console": "integratedTerminal",
      "serverReadyAction": {
        "action": "debugWithEdge",
        "pattern": "Now listening on:\\s+(https?://\\S+)",
        "uriFormat": "%s",
        "webRoot": "${workspaceFolder}/src/PoMiniApps.Web"
      }
    },
    {
      "name": "PoMiniApps.Web (Server)",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build-server",
      "program": "${workspaceFolder}/src/PoMiniApps.Web/bin/Debug/net10.0/PoMiniApps.Web.dll",
      "args": [],
      "cwd": "${workspaceFolder}/src/PoMiniApps.Web",
      "stopAtEntry": false,
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development",
        "ASPNETCORE_URLS": "https://localhost:5001;http://localhost:5000"
      },
      "sourceFileMap": {
        "/Views": "${workspaceFolder}/Views"
      },
      "console": "integratedTerminal"
    },
    {
      "name": "PoMiniApps.Web (Browser)",
      "type": "pwa-msedge",
      "request": "launch",
      "url": "https://localhost:5001",
      "webRoot": "${workspaceFolder}/src/PoMiniApps.Web",
      "presentation": {
        "hidden": true
      }
    }
  ],
  "compounds": [
    {
      "name": "PoMiniApps (Full Stack)",
      "configurations": [
        "PoMiniApps.Web (Server)",
        "PoMiniApps.Web (Browser)"
      ],
      "preLaunchTask": "cleanup-dotnet-processes",
      "stopAll": true,
      "presentation": {
        "hidden": false,
        "group": "PoMiniApps",
        "order": 1
      }
    }
  ]
}